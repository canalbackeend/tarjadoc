# Database PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/tarjadoc

# JWT Secret (gere uma chave segura para produção - mínimo 32 caracteres)
JWT_SECRET=sua-chave-jwt-segura-aqui-mude-em-producao

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# SMTP (Hostinger)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu-email@seudominio.com
SMTP_PASS=sua-senha
SMTP_FROM="TarjaDOC" <seu-email@seudominio.com>

# App
NODE_ENV=development
APP_URL=https://tarjadoc.beend.tech
