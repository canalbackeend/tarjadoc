# Database PostgreSQL (obrigatório)
DATABASE_URL=postgresql://user:password@host:5432/tarjadoc

# JWT Secret (obrigatório - mínimo 32 caracteres)
JWT_SECRET=sua-chave-segura-aqui-minimo-32-caracteres

# Stripe (obrigatório para pagamentos)
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# SMTP Email (obrigatório para recuperação de senha)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu-email@seudominio.com
SMTP_PASS=sua-senha
SMTP_FROM="TarjaDOC" <seu-email@seudominio.com>

# App
NODE_ENV=production
APP_URL=https://seudominio.com
PORT=3000

# Admin (criado automaticamente se não existir)
ADMIN_EMAIL=admin@seudominio.com
ADMIN_PASSWORD=admin123
